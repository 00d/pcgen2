{"slug":"burn-it","name":"Burn It!","level":1,"category":"ancestry","prerequisites":[],"actionType":"passive","actions":null,"maxTakeable":null,"traits":{"value":["goblin"]},"rules":[{"damageType":"fire","key":"FlatModifier","predicate":["item:trait:alchemical"],"selector":"strike-damage","slug":"burn-it-strike","type":"status","value":"max(floor(@weapon.level/4), 1)"},{"damageType":"fire","key":"FlatModifier","selector":"spell-damage","slug":"burn-it-spell","type":"status","value":"max(floor(@spell.level/2), 1)"},{"damageCategory":"persistent","damageType":"fire","key":"FlatModifier","selector":"damage","slug":"burn-it-persistent","type":"status","value":1}],"description":"Fire fascinates you. Your spells and alchemical items that deal fire damage gain a status bonus to damage equal to half the spell's rank or one-quarter the item's level (minimum bonus +1). You also gain a +1 status bonus to any persistent fire damage you deal.","publication":{"license":"ORC","remaster":true,"title":"Pathfinder Player Core"}}